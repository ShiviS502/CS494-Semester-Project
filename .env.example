# ─── Anthropic API Key ────────────────────────────────────────────────────────
# Used by: Orchestrator, Diagnosis, Strategy, Critic agents (Claude models)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-your-key-here

# ─── OpenAI API Key ───────────────────────────────────────────────────────────
# Used by: Data Intelligence agent (GPT-3.5-turbo) + ChromaDB embeddings
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ─── ChromaDB Storage Path (optional) ────────────────────────────────────────
# Local directory where ChromaDB persists vector embeddings
# Default: ./chroma_db
CHROMA_PATH=./chroma_db
